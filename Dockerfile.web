# --- Étape 1 : Build Node.js ---
FROM node:14-bullseye AS node-build
WORKDIR /app

# Outils de build
RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*

ENV NODE_OPTIONS="--max-old-space-size=2048"

COPY package*.json ./
# Installation propre
RUN npm install --no-audit --no-fund --legacy-peer-deps

COPY . .
# Retour à npm run production (maintenant que la mémoire est boostée, le PATH sera correct)
RUN npm run production

# --- Étape 2 : Serveur PHP/Apache ---
FROM php:8.1-apache

ENV APACHE_DOCUMENT_ROOT /var/www/html/public
WORKDIR /var/www/html

RUN apt-get update && apt-get install -y \
    git curl libpng-dev libjpeg-dev libfreetype6-dev libonig-dev libxml2-dev libicu-dev libzip-dev zip unzip \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install pdo_mysql mbstring exif pcntl bcmath gd intl zip

RUN a2enmod rewrite
RUN sed -ri -e 's!/var/www/html!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/sites-available/*.conf
RUN sed -ri -e 's!/var/www/!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/apache2.conf /etc/apache2/conf-available/*.conf

COPY . .
# Copie des assets compilés
COPY --from=node-build /app/public/js ./public/js
COPY --from=node-build /app/public/css ./public/css
COPY --from=node-build /app/public/mix-manifest.json ./public/mix-manifest.json

COPY --from=composer:latest /usr/bin/composer /usr/bin/composer
RUN composer config audit.block-insecure false && \
    composer install --no-dev --optimize-autoloader

RUN chown -R www-data:www-data /var/www/html \
    && chmod -R 775 /var/www/html/storage \
    && chmod -R 775 /var/www/html/bootstrap/cache

COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

EXPOSE 80
ENTRYPOINT ["docker-entrypoint.sh"]
